# =========================
# MySQL
# =========================
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=tfg_restaurante
MYSQL_USER=tfg
MYSQL_PASSWORD=tfg

# =========================
# n8n (chatbot)
# =========================
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# =========================
# Correo del proyecto (Gmail) DESDE AQUI ES LO NUEVO PARA LAS CUENTAS Y COAS DE CORREO NO SE ESTA UTILIZANDO NADA DE ESTO EN EL PROYECTO, PERO LO DEJO POR SI QUEREIS USARLO PARA AVISOS DESDE N8N O COSAS ASI
# =========================
MAILER_EMAIL=sonsofburger.tfg@gmail.com
MAILER_APP_PASSWORD=xxxx xxxx xxxx xxxx
MAILER_FROM_NAME=Sons of Burger

# SMTP para Gmail
MAILER_SMTP_HOST=smtp.gmail.com
MAILER_SMTP_PORT=465
MAILER_SMTP_ENCRYPTION=ssl

# =========================
# Symfony Mailer
# =========================
MAILER_DSN=smtp://sonsofburger.tfg%40gmail.com:xxxx%20xxxx%20xxxx%20xxxx@smtp.gmail.com:465?encryption=ssl&auth_mode=login

# =========================
# n8n SMTP (por si luego queréis avisos desde n8n)
# =========================
N8N_SMTP_HOST=smtp.gmail.com
N8N_SMTP_PORT=465
N8N_SMTP_USER=sonsofburger.tfg@gmail.com
N8N_SMTP_PASS=xxxx xxxx xxxx xxxx
N8N_SMTP_SENDER=sonsofburger.tfg@gmail.com
N8N_SMTP_SSL=true



# =========================
# No va la contraseña normal de Gmail

# No pones la contraseña con la que entras en Gmail cada día.

# Va una “contraseña de aplicación”

# Google te deja crear una clave especial de 16 caracteres para apps externas como n8n o Symfony Mailer, siempre que actives antes la verificación en dos pasos.

# Ejemplo

# Tu contraseña normal podría ser algo como:

# MiClavePersonal123

# Pero la que usarías en el .env sería otra distinta, generada por Google, algo tipo:

# abcd efgh ijkl mnop

# Eso es lo que yo puse como:

# xxxx xxxx xxxx xxxx

# Era solo un relleno de ejemplo.

# Entonces, qué tienes que hacer tú
# 1. Crear el Gmail del proyecto

# Por ejemplo:

# sonsofburger.tfg@gmail.com
# 2. Activar la verificación en dos pasos

# Google exige eso para poder crear una contraseña de aplicación.

# 3. Generar la contraseña de aplicación

# Google te dará una clave de 16 caracteres, que es la que usarás en:

# Symfony

# n8n

# 4. Pegar esa clave en el .env

# Por ejemplo:

# MAILER_EMAIL=sonsofburger.tfg@gmail.com
# MAILER_APP_PASSWORD=abcd efgh ijkl mnop

# Y también en:

# N8N_SMTP_PASS=abcd efgh ijkl mnop